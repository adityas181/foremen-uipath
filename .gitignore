# =============================================================================
# .gitignore  —  FOREMAN (UiPath AgentHack)
# Place at repo root. Keeps secrets and build-junk out of the public repo.
# NOTE: .gitignore only stops UNtracked files. Anything already committed stays
# in history — run cleanup-before-push.sh BEFORE your first commit.
# =============================================================================

# ---- Secrets / credentials (NEVER commit) ----
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
.uipath/                 # UiPath CLI auth state -> .auth.json (live tokens)
**/.uipath/
*.auth.json
**/.auth.json

# ---- UiPath / Python build output ----
__uipath/
**/__uipath/
.agent/
**/.agent/
*.nupkg
*.uip                    # packed agent artifacts (re-created by `uipath pack`)

# ---- Python ----
__pycache__/
**/__pycache__/
*.py[cod]
.venv/
venv/
.uv/

# ---- Node / frontend build (UI/) ----
node_modules/
**/node_modules/
dist/
dist-ssr/
*.local
.vercel/

# ---- Local run outputs (contain real phone numbers / call SIDs) ----
out.json
**/out.json

# ---- Raw coding-agent transcripts (contain printed secrets) ----
# Keep docs/coding-agent/*.md (clean) but never the raw session logs:
docs/coding-agent/*.jsonl

# ---- Logs / scratch ----
*.tmp
*.log

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp