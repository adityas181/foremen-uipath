# ── FOREMAN UI (live) ────────────────────────────────────────────────────────
# The UI binds to a real CaseEvent stream over WebSocket from the view-backend.
# Copy this to `.env` and point it at your backend (localhost, or your tunnel:
#   VITE_FEED_WS_URL=wss://<your-tunnel-host>.trycloudflare.com/ws ).
VITE_FEED_WS_URL=ws://localhost:8000/ws
