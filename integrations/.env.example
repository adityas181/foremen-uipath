# =============================================================================
# integrations/.env.example  ->  copy to integrations/.env and fill in.
# Used by voice_server.py (the FastAPI Twilio webhook).  NEVER commit .env.
# =============================================================================

UIPATH_URL=https://<your-cloud>.uipath.com/<org>/<tenant>
UIPATH_TENANT_ID=
UIPATH_ORGANIZATION_ID=
UIPATH_ACCESS_TOKEN=

# ---- Twilio (voice) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX        # voice-capable number (NOT the WhatsApp sandbox)

# ---- FOREMAN backend / live UI feed ----
FOREMAN_BACKEND_URL=http://localhost:8000
FOREMAN_INGEST_SECRET=
VOICE_WEBHOOK_URL=
