# =============================================================================
# agents/.env.example  ->  copy to agents/.env and fill in.  NEVER commit .env.
# These are read env-first; in Orchestrator the same values live as Assets in
# the "Shared" folder (UIPATH_* come from `uipath auth`, not from here).
# =============================================================================

# ---- UiPath platform ----
UIPATH_URL=https://<your-cloud>.uipath.com/<org>/<tenant>
UIPATH_TENANT_ID=
UIPATH_ORGANIZATION_ID=
# UIPATH_ACCESS_TOKEN is written automatically by `uipath auth`. Only set it by
# hand if you skip interactive login (UiPathChat LLM client requires it in env).
UIPATH_ACCESS_TOKEN=
UIPATH_PAT=

# ---- Gmail (foreman-email) — App Password, NOT your Google login ----
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ---- FOREMAN backend / live UI feed ----
FOREMAN_BACKEND_URL=http://localhost:8001
FOREMAN_INGEST_SECRET=

# ---- Neo4j AuraDB (foreman-fleet-blast-radius) ----
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
AURA_INSTANCEID=

# ---- Google Gemini (foreman-vision) ----
GEMINI_API_KEY=

# ---- Twilio voice webhook (foreman-voice) ----
# Public HTTPS URL of voice_server.py, e.g. from `cloudflared tunnel`.
VOICE_WEBHOOK_URL=

# ---- Weather MCP (foreman-weather) — UiPath-hosted MCP endpoint ----
WEATHER_MCP_URL=
