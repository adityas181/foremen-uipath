        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(!vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == 'Stage 1' || stage.stageName == 'Human Safety Review' || stage.stageName == ' Close ticket' || stage.stageName == 'Perceive' || stage.stageName == 'Investigate' || stage.stageName == 'Voice Escalation'))</bpmn:conditionExpression>
