      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_vTlJ0h" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_vTlJ0h">
