      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_ghS7aJ" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_ghS7aJ">
